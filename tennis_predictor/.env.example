# Backend
PYTHONPATH=./backend

# Database
DATABASE_URL=postgresql+asyncpg://postgres:postgres@db:5432/tennis_predictor
DATABASE_URL_SYNC=postgresql://postgres:postgres@db:5432/tennis_predictor

# Redis
REDIS_URL=redis://redis:6379/0

# Telegram
TELEGRAM_BOT_TOKEN=your_bot_token_here
TELEGRAM_BOT_USERNAME=your_bot_username_here

# Mini App
MINI_APP_URL=https://your-domain.com
FRONTEND_URL=http://localhost:5173

# Tennis API
TENNIS_API_URL=https://api.example.com
TENNIS_API_KEY=your_api_key_here

# News API
NEWS_API_KEY=your_news_api_key_here

# LLM
LLM_API_KEY=your_llm_api_key_here
LLM_MODEL=gpt-3.5-turbo

# ML
MODEL_PATH=./models/predictor.pkl

# Logging
LOG_LEVEL=INFO

# Security
SECRET_KEY=your_secret_key_here
ALGORITHM=HS256
ACCESS_TOKEN_EXPIRE_MINUTES=30
